Jinja2


! =======================================================
! Device: {{ item.hostname }}
! Site: {{ item.site }}
! Generated by Ansible + Jinja2
! Engineer: Hari Sundar A
! =======================================================
!
hostname {{ item.hostname }}
!
! Interface Configuration
{% for interface in item.interfaces %}
interface {{ interface.name }}
 description {{ interface.description }}
 ip address {{ interface.ip }} {{ interface.mask }}
 no shutdown
!
{% endfor %}
!
! Routing Configuration
router ospf {{ item.ospf_process }}
 router-id {{ item.router_id }}
{% for network in item.ospf_networks %}
 network {{ network.ip }} {{ network.wildcard }} area {{ network.area }}
{% endfor %}
!
! BGP Configuration
{% if item.bgp_enabled %}
router bgp {{ item.bgp_as }}
 bgp router-id {{ item.router_id }}
{% for peer in item.bgp_peers %}
 neighbor {{ peer.ip }} remote-as {{ peer.as }}
 neighbor {{ peer.ip }} description {{ peer.name }}
{% endfor %}
{% endif %}
!
! NTP Configuration
{% for ntp in item.ntp_servers %}
ntp server {{ ntp }}
{% endfor %}
!
! Security Hardening
ip shh version 2
no service telnet
service password-encryption
!
! Standard Banner
banner motd ^
    Authorized Access Only
    Device: {{ item.hostname }}
    Site: {{ item.site }}
    Unauthorized access is prohibited
^
!
! SNMP Configuration
snmp-server community {{ item.snmp_community }} RO
snmp-server location {{ item.site }}
snmp-server contact {{ item.contact_email }}
!
end
